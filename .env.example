# Cambia esta clave por una cadena larga y aleatoria antes de publicar la app.
SECRET_KEY=cambia-esta-clave-larga-y-segura

# Opcional. En nube se recomienda apuntar a un disco persistente.
# Ejemplo Render: /var/data/lab_inventory.db
DATABASE_PATH=lab_inventory.db

# Opcional. Puerto local.
PORT=5000

# 0 para producción, 1 solo para pruebas locales.
FLASK_DEBUG=0
